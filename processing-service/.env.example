# Database (RDS in prod; local docker-compose for dev)
DATABASE_URL=postgresql://dev:dev@localhost:5432/architect_ledger

# Redis (ElastiCache in prod)
REDIS_URL=redis://localhost:6379

# Claude API (used for all agent reasoning AND document extraction)
CLAUDE_API_KEY=sk-ant-...

# Mistral (embeddings only — for lesson store similarity search)
MISTRAL_API_KEY=...

# AWS / S3
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=architect-ledger-docs
# For local MinIO dev: set to http://localhost:9000
# AWS_ENDPOINT_URL=http://localhost:9000

# SendGrid
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@architectledger.com

# Xero OAuth
XERO_CLIENT_ID=...
XERO_CLIENT_SECRET=...
